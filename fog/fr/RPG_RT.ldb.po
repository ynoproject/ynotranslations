#. ID 1
msgctxt "items.name"
msgid "Radio"
msgstr ""

#. ID 1
msgctxt "items.description"
msgid "It's my first contact with the outside world."
msgstr "C'est mon premier contact avec le monde extérieur."

#. ID 2
msgctxt "items.name"
msgid "Rain Boots"
msgstr "Bottes de pluie"

#. ID 2
msgctxt "items.description"
msgid "They go out and party, but I don't care."
msgstr "Elles sortent et font la fête, mais je m'en fiche."

#. ID 3
msgctxt "items.name"
msgid "Floppy Disk"
msgstr "Disquette"

#. ID 3
msgctxt "items.description"
msgid "Not even 100 years later."
msgstr "Même pas 100 ans plus tard."

#. ID 4
msgctxt "items.name"
msgid "Stress Balls"
msgstr "Balles anti-stress"

#. ID 4
msgctxt "items.description"
msgid "The \"greater struggle\"? I believe it!"
msgstr "Le « grand combat » ? J'y crois !"

#. ID 5
msgctxt "items.name"
msgid "Paintbrush"
msgstr "Pinceau"

#. ID 5
msgctxt "items.description"
msgid "Sometimes words don't describe."
msgstr "Des fois, les mots n'arrivent pas à décrire."

#. ID 6
msgctxt "items.name"
msgid "Cell Phone"
msgstr "Téléphone cellulaire"

#. ID 6
msgctxt "items.description"
msgid "Tegan would make better use of this."
msgstr "Tegan en aurait plus l'utilité."

#. ID 7
msgctxt "items.name"
msgid "Jawbreaker"
msgstr "Boule de mammouth"

#. ID 7
msgctxt "items.description"
msgid "My favorite candy."
msgstr "Mon bonbon favori."

#. ID 8
msgctxt "items.name"
msgid "Beanie"
msgstr "Bonnet"

#. ID 8
msgctxt "items.description"
msgid "This is Martha's. Is she okay?"
msgstr "C'est celui de Martha. Est-ce qu'elle va bien ?"

#. ID 9
msgctxt "items.name"
msgid "Incense"
msgstr "Encens"

#. ID 9
msgctxt "items.description"
msgid "You know, for relaxation."
msgstr "Tu sais, pour se relaxer."

#. ID 10
msgctxt "items.name"
msgid "Pen"
msgstr "Stylo"

#. ID 10
msgctxt "items.description"
msgid "Sometimes words do describe."
msgstr "Des fois, les mots arrivent à décrire."

#. ID 11
msgctxt "items.name"
msgid "Magazine"
msgstr ""

#. ID 11
msgctxt "items.description"
msgid "It's about heavy metal."
msgstr "C'est sur l'heavy metal."

#. ID 12
msgctxt "items.name"
msgid "Space Suit"
msgstr "Combinaison spatiale"

#. ID 12
msgctxt "items.description"
msgid "You can't breathe in space. So..."
msgstr "Tu ne peux pas respirer dans l'espace. Donc..."

#. ID 13
msgctxt "items.name"
msgid "Comic Book"
msgstr "Comic book"

#. ID 13
msgctxt "items.description"
msgid "Ts*k*T*b #12, my favorite issue!"
msgstr "Ts*k*T*b volume 12, mon favori !"

#. ID 14
msgctxt "items.name"
msgid "Puzzle Box"
msgstr "Boîte de puzzle"

#. ID 14
msgctxt "items.description"
msgid "Never figured out how to open it..."
msgstr "J'ai jamais compris comment l'ouvrir..."

#. ID 15
msgctxt "items.name"
msgid "Potato"
msgstr "Patate"

#. ID 15
msgctxt "items.description"
msgid "What's this for? Physics lab?"
msgstr "Elle sert à quoi ? C'est pour un labo de physique ?"

#. ID 16
msgctxt "items.name"
msgid "Laptop"
msgstr "Ordinateur portable"

#. ID 16
msgctxt "items.description"
msgid "Nothing is real anymore."
msgstr "Plus rien n'est réel désormais."

#. ID 17
msgctxt "items.name"
msgid "Beret"
msgstr "Béret"

#. ID 17
msgctxt "items.description"
msgid "But I already have one!"
msgstr "Mais j'en ai déjà un !"

#. ID 18
msgctxt "items.name"
msgid "Cappuccino"
msgstr ""

#. ID 18
msgctxt "items.description"
msgid "A futile escape. I'll have another."
msgstr "Un échappatoire inutile. J'en prendrai un autre."

#. ID 19
msgctxt "items.name"
msgid "Dark Matter"
msgstr "Matière noire"

#. ID 19
msgctxt "items.description"
msgid "Nothing matters anymore."
msgstr "Plus rien ne compte maintenant."

#. ID 20
msgctxt "items.name"
msgid "Crystal"
msgstr "Cristal"

#. ID 20
msgctxt "items.description"
msgid "If I get the blood off..."
msgstr "Si j'arrive à retirer le sang..."

#. ID 21
msgctxt "items.name"
msgid "Spork"
msgstr "Cuillère-fourchette"

#. ID 21
msgctxt "items.description"
msgid "What's this for?"
msgstr "Ça sert à quoi ?"

#. ID 22
msgctxt "items.name"
msgid "Medallion"
msgstr "Médaillon"

#. ID 22
msgctxt "items.description"
msgid "What will I work for?"
msgstr "Qu'est-ce que je cherche, au fond ?"

#. ID 23
msgctxt "items.name"
msgid "Piece of Fog"
msgstr "Bout de brouillard"

#. ID 23
msgctxt "items.description"
msgid "It's not the fog outside I'm worried about..."
msgstr "Le brouillard dehors n'est pas ce qui m'inquiète..."

#. ID 24
msgctxt "items.name"
msgid "Dunce Cap"
msgstr "Bonnet d'âne"

#. ID 24
msgctxt "items.description"
msgid "Sometimes we learn what we don't want to know."
msgstr "Des fois, on apprend ce que l'on ne voulait pas."

#. ID 25
msgctxt "items.name"
msgid "Worn Out Book"
