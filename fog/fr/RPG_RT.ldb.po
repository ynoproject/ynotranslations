#. ID 33
msgctxt "items.name"
msgid "Newspaper"
msgstr "Journal"

#. ID 33
msgctxt "items.description"
msgid "Sometimes too upsetting."
msgstr "Des fois trop agaçant."

#. ID 34
msgctxt "items.name"
msgid "Needle"
msgstr "Aiguille"

