#. ID 31
msgctxt "items.name"
msgid "Bell Collar"
msgstr "Collier à cloches"

#. ID 31
msgctxt "items.description"
msgid "Don't ask."
msgstr "Demandez pas."

#. ID 32
msgctxt "items.name"
msgid "Bottle"
msgstr "Bouteille"

