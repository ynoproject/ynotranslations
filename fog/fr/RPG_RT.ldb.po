msgctxt "items.description"
msgid "Why didn't they give me a phone?"
msgstr "Pourquoi ne m'ont-ils pas donné un téléphone ?"

#. ID 27
msgctxt "items.name"
msgid "Cherry"
msgstr "Cerise"

