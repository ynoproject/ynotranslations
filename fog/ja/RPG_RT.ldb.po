#. ID 1
msgctxt "items.name"
msgid "Radio"
msgstr "ラジオ"

#. ID 1
msgctxt "items.description"
msgid "It's my first contact with the outside world."
msgstr "外界との最初の接触だ。"

#. ID 2
msgctxt "items.name"
msgid "Rain Boots"
msgstr "レインブーツ"

#. ID 2
msgctxt "items.description"
msgid "They go out and party, but I don't care."
msgstr "人々は遊びに出かけてパーティをしているけど…"

#. ID 3
msgctxt "items.name"
msgid "Floppy Disk"
msgstr "フロッピーディスク"

#. ID 3
msgctxt "items.description"
msgid "Not even 100 years later."
msgstr "100年も経たないうちに…"

#. ID 4
msgctxt "items.name"
msgid "Stress Balls"
msgstr "ストレスボール"

#. ID 4
msgctxt "items.description"
msgid "The \"greater struggle\"? I believe it!"
msgstr "「より大きな対立？」信じるよ。"

#. ID 5
msgctxt "items.name"
msgid "Paintbrush"
msgstr "えふで"

#. ID 5
msgctxt "items.description"
msgid "Sometimes words don't describe."
msgstr "時々言葉は説明しない。"

#. ID 6
msgctxt "items.name"
msgid "Cell Phone"
msgstr "けいたいでんわ"

#. ID 6
msgctxt "items.description"
msgid "Tegan would make better use of this."
msgstr "ティーガンはより良く活用するだろう。"

#. ID 7
msgctxt "items.name"
msgid "Jawbreaker"
msgstr "ジョーブレイカー"

#. ID 7
msgctxt "items.description"
msgid "My favorite candy."
msgstr "お気に入りのキャンディだ。"

#. ID 8
msgctxt "items.name"
msgid "Beanie"
msgstr "ビーニー"

#. ID 8
msgctxt "items.description"
msgid "This is Martha's. Is she okay?"
msgstr "これはマーサのもの。大丈夫かな…"

#. ID 9
msgctxt "items.name"
msgid "Incense"
msgstr "こう"

#. ID 9
msgctxt "items.description"
msgid "You know, for relaxation."
msgstr "ほら、リラックスするためだよ。"

#. ID 10
msgctxt "items.name"
msgid "Pen"
msgstr "ペン"

#. ID 10
msgctxt "items.description"
msgid "Sometimes words do describe."
msgstr "時々言葉は説明するね。"

#. ID 11
msgctxt "items.name"
msgid "Magazine"
msgstr "ざっし"

#. ID 11
msgctxt "items.description"
msgid "It's about heavy metal."
msgstr "ヘビーメタルのことだ。"

#. ID 12
msgctxt "items.name"
msgid "Space Suit"
msgstr "うちゅうふく"

#. ID 12
msgctxt "items.description"
msgid "You can't breathe in space. So..."
msgstr "宇宙で呼吸できないので…"

#. ID 13
msgctxt "items.name"
msgid "Comic Book"
msgstr "まんが"

#. ID 13
msgctxt "items.description"
msgid "Ts*k*T*b #12, my favorite issue!"
msgstr "お気に入り！ツ〇タブの第１２巻"

#. ID 14
msgctxt "items.name"
msgid "Puzzle Box"
msgstr "パズルボックス"

#. ID 14
msgctxt "items.description"
msgid "Never figured out how to open it..."
msgstr "どうやって開けるのか、結局わからなかった…"

#. ID 15
msgctxt "items.name"
msgid "Potato"
msgstr "ジャガイモ"

#. ID 15
msgctxt "items.description"
msgid "What's this for? Physics lab?"
msgstr "何のためのもの？物理ラボ？"

#. ID 16
msgctxt "items.name"
msgid "Laptop"
msgstr "ノートパソコン"

#. ID 16
msgctxt "items.description"
msgid "Nothing is real anymore."
msgstr "もう、何もかもが現実ではない。"

#. ID 17
msgctxt "items.name"
msgid "Beret"
msgstr "ベレー"

#. ID 17
msgctxt "items.description"
msgid "But I already have one!"
msgstr "でも、ベレーはすでにあるよ。"

#. ID 18
msgctxt "items.name"
msgid "Cappuccino"
msgstr "カプチーノ"

#. ID 18
msgctxt "items.description"
msgid "A futile escape. I'll have another."
msgstr "無益な脱出なので、もう一本をお願いします。"

#. ID 19
msgctxt "items.name"
msgid "Dark Matter"
msgstr "あんこくぶっしつ"

#. ID 19
msgctxt "items.description"
msgid "Nothing matters anymore."
msgstr "もう、何もかもどうでもいいだ。"

#. ID 20
msgctxt "items.name"
msgid "Crystal"
msgstr "すいしょう"

#. ID 20
msgctxt "items.description"
msgid "If I get the blood off..."
msgstr "血を拭き取れば…"

#. ID 21
msgctxt "items.name"
msgid "Spork"
msgstr "さきわれスプーン"

#. ID 21
msgctxt "items.description"
msgid "What's this for?"
msgstr "なぜこれなの？"

#. ID 22
msgctxt "items.name"
msgid "Medallion"
msgstr "メダリオン"

#. ID 22
msgctxt "items.description"
msgid "What will I work for?"
msgstr "報酬は何だろう…"

#. ID 23
msgctxt "items.name"
msgid "Piece of Fog"
msgstr "いっぺんのきり"

#. ID 23
msgctxt "items.description"
msgid "It's not the fog outside I'm worried about..."
msgstr "外の霧については心配してない…"

#. ID 24
msgctxt "items.name"
msgid "Dunce Cap"
msgstr "とんがりぼうし"

#. ID 24
msgctxt "items.description"
msgid "Sometimes we learn what we don't want to know."
msgstr "時々禁断のもの学ぶ。"

#. ID 25
msgctxt "items.name"
msgid "Worn Out Book"
msgstr "ふるいノート"

#. ID 25
msgctxt "items.description"
msgid "Not my dream diary..."
msgstr "ボクの夢日記じゃない…"

#. ID 26
msgctxt "items.name"
msgid "Pager"
msgstr "ポケベル"

#. ID 26
msgctxt "items.description"
msgid "Why didn't they give me a phone?"
msgstr "なぜ両親はあたしに携帯電話をあげてくれなかったの？"

#. ID 27
msgctxt "items.name"
msgid "Cherry"
msgstr "さくらんぼう"

#. ID 27
msgctxt "items.description"
msgid "Everything's better with this on top."
msgstr "これがあればすべてがもっと良くなるわ。"

#. ID 28
msgctxt "items.name"
msgid "Portrait"
msgstr "しょうぞうが"

#. ID 28
msgctxt "items.description"
msgid "This was us..."
msgstr "うちだったね…"

#. ID 29
msgctxt "items.name"
msgid "Pencil"
msgstr "えんぴつ"

#. ID 29
msgctxt "items.description"
msgid "I draw and doodle a lot."
msgstr "よく絵を描くわ。"

#. ID 30
msgctxt "items.name"
msgid "Glasses"
msgstr "メガネ"

#. ID 30
msgctxt "items.description"
msgid "I'm supposed to wear those too."
msgstr "あたしもこれをかけることになってるのわ。"

#. ID 31
msgctxt "items.name"
msgid "Bell Collar"
msgstr "すずつきくびわ"

#. ID 31
msgctxt "items.description"
msgid "Don't ask."
msgstr "秘密だよ。"

#. ID 32
msgctxt "items.name"
msgid "Bottle"
msgstr "ボトル"

#. ID 32
msgctxt "items.description"
msgid "Can't drink out of this anymore..."
msgstr "もうこれから飲めないな…"

#. ID 33
msgctxt "items.name"
msgid "Newspaper"
msgstr "しんぶん"

#. ID 33
msgctxt "items.description"
msgid "Sometimes too upsetting."
msgstr "時々あまりにも辛いな…"

#. ID 34
msgctxt "items.name"
msgid "Needle"
msgstr "はり"

#. ID 34
msgctxt "items.description"
msgid "I should learn to sew costumes sometime."
msgstr "いつか、衣装の縫い方を習うべきだ。"

#. ID 35
msgctxt "items.name"
msgid "Eyeball"
msgstr "めだま"

#. ID 35
msgctxt "items.description"
msgid "Eww, and it's kind of big!"
msgstr "うわ～なんだか大きいな！"

#. ID 36
msgctxt "items.name"
msgid "Heart"
msgstr "ハート"

#. ID 36
msgctxt "items.description"
msgid "Oh my God, that's a pumping human heart!"
msgstr "なんて！拍動する心臓だ！"

#. ID 37
msgctxt "items.name"
msgid "Guitar"
msgstr "ギター"

#. ID 37
msgctxt "items.description"
msgid "Feldon said I could always borrow this..."
msgstr "フェルドンはこれをいつも借りてもいいと言ったわ。"

#. ID 38
msgctxt "items.name"
msgid "Sketchbook"
msgstr "スケッチブック"

#. ID 38
msgctxt "items.description"
msgid "The drawings are a little... unsettling?"
msgstr "絵は…不穏？"

#. ID 39
msgctxt "items.name"
msgid "Bloody Knife"
msgstr "ちまみれのほうちょう"

#. ID 39
msgctxt "items.description"
msgid "But I didn't kill Martha!"
msgstr "でも、マーサちゃんを殺さなかったわよ！"

#. ID 40
msgctxt "items.name"
msgid "Red Marker"
msgstr "あかいマーカー"

#. ID 40
msgctxt "items.description"
msgid "I use this to draw bad feelings."
msgstr "これで嫌な予感の絵を描くわ。"

#. ID 41
msgctxt "items.name"
msgid "Skull"
msgstr "どくろ"

#. ID 41
msgctxt "items.description"
msgid "Why am I carrying this!?"
msgstr "なぜこれを持ち歩いてるの！？"

#. ID 42
msgctxt "items.name"
msgid "Wart"
msgstr "いぼ"

#. ID 42
msgctxt "items.description"
msgid "It's sticky, and an eye is coming out of it!"
msgstr "ねばねばで、目は飛び出してるな！"

#. ID 43
msgctxt "items.name"
msgid "Martha's Voice"
msgstr "マーサのこえ"

#. ID 43
msgctxt "items.description"
msgid "Why? Get it out! Get it out!"
msgstr "なぜ？去って！去って！"

#. ID 44
msgctxt "items.name"
msgid "Dream Diary"
msgstr "ゆめにっき"

#. ID 44
msgctxt "items.description"
msgid "My old dream journal! Let's keep it shut forever."
msgstr "古い夢日記だ！永遠に閉ざしておこうわ。"

#. ID 45
msgctxt "items.name"
msgid "Fidget Spinner"
msgstr "ハンドスピナー"

#. ID 45
msgctxt "items.description"
msgid "I think one of my friends would like this."
msgstr "友達の一人はこれが好きだと思うね。"

